{
  "root": false,
  "extends": ["@filecoin-pay/configs/biome/base"],
  "linter": {
    "enabled": true,
    "includes": ["**", "!dist", "!templates"],
    "rules": {
      "preset": "recommended",
      "style": { "useImportType": "off", "noNonNullAssertion": "off" },
      "suspicious": {
        "noShadowRestrictedNames": "off",
        "noDoubleEquals": "off"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      }
    }
  }
}
